---
import DynamicBackground from '../components/DynamicBackground.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="John Carlson - Developer portfolio" />
    <link rel="icon" type="image/png" href="/images/avatar.png" />
    <link rel="preload" as="image" href="/images/bg-skater.jpg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400&family=Playfair+Display&display=swap" />
    <title>{title}</title>
  </head>
  <body>
    <DynamicBackground />
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
