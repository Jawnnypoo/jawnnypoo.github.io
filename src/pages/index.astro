---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import portfolioData from '../data/portfolio.json';

const year = new Date().getFullYear();
const gravatarUrl = 'https://www.gravatar.com/avatar/66372cf8a4b4dfad56d5dc4ddd4af34e';

const professionalProjects = portfolioData.projects.filter(p => p.type === 'professional');
const personalProjects = portfolioData.projects.filter(p => p.type === 'personal');
const libraryProjects = portfolioData.projects.filter(p => p.type === 'library');
---

<BaseLayout title="John Carlson | @Jawnnypoo">
  <!-- Hero -->
  <section class="hero">
    <div class="card">
      <img
        src={`${gravatarUrl}?s=512`}
        alt="John Carlson"
        class="avatar"
        width="200"
        height="200"
      />

      <h1 class="logo">John Carlson | @Jawnnypoo</h1>

      <p class="bio">
        Hey there, I'm John.
      </p>
      <p class="bio">
        I'm a serious developer trying not to take life too seriously.
      </p>
      <p class="bio">
        I create things with my friends under Commit 451
      </p>

      <a href="#portfolio" class="cta">See My Portfolio</a>

      <div class="socials">
        <a href="https://github.com/Jawnnypoo" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/jawnnypoo/" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://play.google.com/store/apps/dev?id=8992288925330781810" target="_blank" rel="noopener noreferrer" class="social-btn" aria-label="Google Play Store">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 010 1.38l-2.302 2.302L15.3 12l2.398-2.492zM5.864 2.658L16.8 9.49l-2.302 2.303L5.864 2.658z"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section id="portfolio" class="portfolio">
    <div class="portfolio-inner">
      <div class="intro">
        <h2 class="section-title">Portfolio</h2>
        <p class="intro-text">
          Here is a sample of some work I've done, professionally and personally. I've also done tons of work as an open sourcerer, which is up on GitHub under both <a href="https://github.com/Jawnnypoo" target="_blank" rel="noopener noreferrer">Jawnnypoo</a> and <a href="https://github.com/Commit451" target="_blank" rel="noopener noreferrer">Commit 451</a>. Android is my passion, but I also have experience in Typescript and Flutter (this site is created with Astro!). Please reach out if you would like a more formal resume as a PDF.
        </p>
      </div>

      <nav class="tabs" aria-label="Project categories">
        <button class="tab active" data-type="professional">Professional</button>
        <button class="tab" data-type="personal">Personal</button>
        <button class="tab" data-type="library">Libraries</button>
      </nav>

      <hr class="divider" />

      <section class="projects-section" data-section="professional">
        {professionalProjects.map(project => (
          <ProjectCard
            name={project.name}
            company={project.company}
            description={project.description}
            images={project.images}
          />
        ))}
      </section>

      <section class="projects-section hidden" data-section="personal">
        {personalProjects.map(project => (
          <ProjectCard
            name={project.name}
            company={project.company}
            description={project.description}
            images={project.images}
          />
        ))}
      </section>

      <section class="projects-section hidden" data-section="library">
        {libraryProjects.map(project => (
          <ProjectCard
            name={project.name}
            company={project.company}
            description={project.description}
            images={project.images}
          />
        ))}
      </section>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <p>&copy; John Carlson {year} &bull; Created with Astro &bull; <a href="https://github.com/Jawnnypoo/jawnnypoo.github.io" target="_blank" rel="noopener noreferrer">See source</a></p>
  </footer>
</BaseLayout>

<style>
  /* --- Hero --- */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/images/bg.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    padding: 2rem;
  }

  .card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    padding: 2.5rem;
    max-width: 600px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .avatar {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: clamp(1.25rem, 3vw, 2.25rem);
    font-weight: 700;
    line-height: 1.2;
  }

  .bio {
    font-size: 1.2rem;
    text-align: center;
    line-height: 1.6;
    color: var(--color-dark);
  }

  .cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    font-weight: 700;
    padding: 0.75rem 2rem;
    border: 2px solid var(--color-dark);
    border-radius: 8px;
    color: var(--color-dark);
    text-decoration: none;
    transition: background-color 0.2s, color 0.2s;
  }

  .cta:hover {
    background: var(--color-dark);
    color: white;
    opacity: 1;
  }

  .socials {
    display: flex;
    gap: 1rem;
  }

  .social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.06);
    color: var(--color-dark);
    text-decoration: none;
    transition: background-color 0.2s, transform 0.2s;
  }

  .social-btn:hover {
    background: rgba(0, 0, 0, 0.12);
    transform: scale(1.1);
    opacity: 1;
  }

  /* --- Portfolio --- */
  .portfolio {
    background: white;
  }

  .portfolio-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .intro {
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-family: var(--font-mono);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .intro-text {
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 80ch;
  }

  .tabs {
    display: flex;
    gap: 0.25rem;
    margin-top: 1.5rem;
  }

  .tab {
    background: none;
    border: none;
    padding: 0.6rem 1.25rem;
    font-size: 1rem;
    color: var(--color-gray);
    cursor: pointer;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }

  .tab:hover {
    background: #f3f4f6;
  }

  .tab.active {
    color: var(--color-primary);
    font-weight: 700;
  }

  .divider {
    border: none;
    border-top: 1px solid #d1d5db;
    margin: 0.5rem 0 1rem;
  }

  .hidden {
    display: none;
  }

  /* --- Footer --- */
  .footer {
    background: var(--color-primary);
    color: white;
    text-align: center;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
  }

  .footer a {
    color: white;
    text-decoration: underline;
  }

  .footer a:hover {
    opacity: 0.85;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', initTabs);
  document.addEventListener('astro:page-load', initTabs);

  function initTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
    const sections = document.querySelectorAll<HTMLElement>('.projects-section');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const type = tab.dataset.type;

        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        sections.forEach(s => {
          s.classList.toggle('hidden', s.dataset.section !== type);
        });
      });
    });
  }
</script>
